<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ .Name }} - Resume</title>
    <style>
        :root {
            --primary-blue: #1a4f7a;
            --text-dark: #222222;
            --text-gray: #555555;
            --border-light: #cccccc;
            --bg-light: #f8f9fa;
        }

        /* --- Reset & Base --- */
        *, *::before, *::after {
            box-sizing: border-box;
        }

        @page {
            size: A4;
            margin: 0 -0.2in;
        }

        body {
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            font-size: 12px;
            line-height: 1.4;
            color: var(--text-dark);
            background-color: #ffffff;
            margin: 0;
        }

        /* --- Links --- */
        a {
            color: var(--text-dark);
            text-decoration: none;
        }

        /* --- Header --- */
        .header {
            text-align: center;
        }

        .header h1 {
            color: var(--primary-blue);
            font-size: 24px;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .cv-title {
            display: flex;
            justify-content: center;
            align-items: baseline;
            gap: 10px;
        }

        .cv-title h1,
        .cv-title h3,
        .cv-title h3 p {
            margin: 0;
            padding: 0;
        }

        .header .tags {
            font-weight: 600;
            color: var(--text-gray);
            text-transform: uppercase;
            font-size: 11px;
            letter-spacing: 1px;
            border-bottom: 1px solid var(--border-light);
        }

        .contact-info {
            display: flex;
            justify-content: center;
            gap: 15px;
            font-size: 11px;
        }

        .contact-info a {
            color: var(--text-gray);
            text-decoration: none;
            display: flex;
            align-items: center;
            transition: color 0.2s;
        }

        .contact-icon {
            width: 13px;
            height: 13px;
            fill: var(--primary-blue);
            padding-right: 4px;
        }

        /* --- Sections --- */
        .section h2 {
            margin-bottom: 4px;
        }

        .section p {
            margin: 0;
        }

        .section-title {
            color: var(--primary-blue);
            font-size: 14px;
            font-weight: 700;
            text-transform: uppercase;
            border-bottom: 2px solid var(--primary-blue);
        }

        .summary-text {
            text-align: justify;
        }

        .summary-text p,
        .job-bullets li p,
        .skill-row p {
            display: inline;
        }

        .skill-row {
            margin-top: 2px;
        }

        .skill-row:last-child {
        }

        .skill-title {
            font-weight: 700;
            font-size: 13px;
            color: var(--primary-blue);
        }

        /* --- Experience & Education Blocks --- */

        .experience {
        }

        .job-block {
        }

        .job-block:last-child {
        }

        .flex-row {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
        }

        .company-name {
            color: var(--primary-blue);
            font-size: 13px;
            font-weight: 700;
        }

        .job-title {
            font-weight: 600;
            color: var(--text-dark);
        }

        .date-text {
            font-weight: 600;
            color: var(--text-gray);
        }

        .location-text {
            color: var(--text-gray);
            font-style: italic;
        }

        .job-bullets {
            margin-top: 0;
            padding-left: 15px;
        }

        .job-bullets li {
            text-align: justify;
        }

        /* --- Print Specific Adjustments --- */
        @media print {
            body {
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }

            a {
                text-decoration: none !important;
            }
        }
    </style>
</head>
<body>

<header class="header">
    <div class="cv-title">
        <h1 style="color: var(--primary-blue);">
            {{ .Name }} |
        </h1>
        <h3 style="font-weight: 600; color: var(--text-gray);">
            {{ .Role | markdown }}
        </h3>
    </div>
    <div class="tags">
        {{ if .Tags }}
            {{ .Tags }}
        {{ end }}
    </div>
    <div class="contact-info">
        <a href="tel:{{ .Socials.Phone }}">
            <svg class="contact-icon" viewBox="0 0 512 512">
                <path d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"/>
            </svg>
            {{ .Socials.Phone }}
        </a>
        <a href="mailto:{{ .Socials.Email }}">
            <svg class="contact-icon" viewBox="0 0 512 512">
                <path d="M48 64C21.5 64 0 85.5 0 112c0 15.1 7.1 29.3 19.2 38.4L236.8 313.6c11.4 8.5 27 8.5 38.4 0L492.8 150.4c12.1-9.1 19.2-23.3 19.2-38.4c0-26.5-21.5-48-48-48H48zM0 176V384c0 35.3 28.7 64 64 64H448c35.3 0 64-28.7 64-64V176L294.4 339.2c-22.8 17.1-54 17.1-76.8 0L0 176z"/>
            </svg>
            {{ .Socials.Email }}
        </a>
        <a href="https://{{ .Socials.LinkedIn }}">
            <svg class="contact-icon" viewBox="0 0 448 512">
                <path d="M416 32H31.9C14.3 32 0 46.5 0 64.3v383.4C0 465.5 14.3 480 31.9 480H416c17.6 0 32-14.5 32-32.3V64.3c0-17.8-14.4-32.3-32-32.3zM135.4 416H69V202.2h66.5V416zm-33.2-243c-21.3 0-38.5-17.3-38.5-38.5S80.9 96 102.2 96c21.2 0 38.5 17.3 38.5 38.5 0 21.3-17.2 38.5-38.5 38.5zm282.1 243h-66.4V312c0-24.8-.5-56.7-34.5-56.7-34.6 0-39.9 27-39.9 54.9V416h-66.4V202.2h63.7v29.2h.9c8.9-16.8 30.6-34.5 62.9-34.5 67.2 0 79.7 44.3 79.7 101.9V416z"/>
            </svg>
            {{ .Socials.LinkedIn }}
        </a>
    </div>
</header>

{{ if .Summary }}
    <section class="section">
        <h2 class="section-title">Professional Summary</h2>
        <p class="summary-text">{{ .Summary | markdown }}</p>
    </section>
{{ end }}

{{ if .Expertise }}
    <section class="section">
        <h2 class="section-title">Technical Expertise</h2>
        <div>
            {{ range .Expertise }}
                <div class="skill-row">
                    <span class="skill-title">{{ .Title }}:</span>
                    {{ range $index, $skill := .Skills }}{{ if $index }}, {{ end }}{{ $skill | markdown }}{{ end }}
                </div>
            {{ end }}
        </div>
    </section>
{{ end }}

{{ if .Experience }}
    <section class="section">
        <h2 class="section-title">Professional Experience</h2>
        {{ range .Experience }}
            <div class="experience">
                <div class="flex-row">
                    <div class="company-name">{{ .Company }}</div>
                    <div class="date-text">{{ .StartDate }}
                        – {{ if .IsCurrent }}Present{{ else }}{{ .EndDate }}{{ end }}</div>
                </div>
                <div class="flex-row">
                    <div class="job-title">{{ .JobTitle }}</div>
                    <div class="location-text">{{ .Location }} {{ if .WorkType }}&bull; {{ .WorkType }}{{ end }}</div>
                </div>
                <div class="job-block">
                    <ul class="job-bullets">
                        {{ range .Bullets }}
                            <li>{{ . | markdown }}</li>
                        {{ end }}
                    </ul>
                </div>
            </div>
        {{ end }}
    </section>
{{ end }}

{{ if .Education }}
    <section class="section">
        <h2 class="section-title">Education</h2>
        {{ range .Education }}

            <div class="flex-row">
                <div class="company-name">{{ .UniName }}</div>
                <div class="date-text">{{ .StartYear }} – {{ .EndYear }}</div>
            </div>
            <div class="flex-row">
                <div class="job-title">{{ .Degree | markdown }}</div>
                <div class="location-text">{{ .Location }}</div>
            </div>

        {{ end }}
    </section>
{{ end }}

{{ if .Certifications }}
    <section class="section">
        <h2 class="section-title">Certifications</h2>
        <ul style="margin-top: 4px; padding-left: 15px;">
            {{ range .Certifications }}
                <li>{{ . | markdown }}</li>
            {{ end }}
        </ul>
    </section>
{{ end }}

</body>
</html>